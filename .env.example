# ─────────────────────────────────────────────────────────────
# Monitor Polític Municipal — Variables d'entorn
# Copia aquest fitxer com a .env.local per al desenvolupament local
# Configura TOTES les variables a Vercel per a producció
# ─────────────────────────────────────────────────────────────

# SUPABASE — obligatòries
# Obtenir a: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# OPENAI — obligatòria per a l'anàlisi IA i l'Assistent
# Obtenir a: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# TELEGRAM — per a les alertes a l'admin (Aitor)
# 1. Parla amb @BotFather a Telegram per crear el bot → obté el TOKEN
# 2. Afegeix el bot a un grup/xat privat
# 3. Envia un missatge al grup i visita:
#    https://api.telegram.org/bot[TOKEN]/getUpdates
#    Busca "chat":{"id": XXXXXXX} → és el teu CHAT_ID
TELEGRAM_BOT_TOKEN=7xxxxxxxxx:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=-100xxxxxxxxxx

# CRON_SECRET — protegeix les rutes /api/cron/* de crides externes
# Genera un secret llarg i aleatori (ex: openssl rand -base64 32)
# Vercel l'envia automàticament als crons configurats a vercel.json
CRON_SECRET=posa-aqui-un-secret-llarg-i-aleatori

# ─────────────────────────────────────────────────────────────
# COM CONFIGURAR A VERCEL
# ─────────────────────────────────────────────────────────────
# 1. Ves a: https://vercel.com/[equip]/[projecte]/settings/environment-variables
# 2. Afegeix CADA variable (sense les cometes del valor)
# 3. Selecciona entorns: Production i Preview
# 4. Fes un nou deploy (o redeploy) per aplicar els canvis
#
# IMPORTANT:
# - SUPABASE_SERVICE_KEY mai ha de ser pública (no NEXT_PUBLIC_)
# - Comprova que les variables estan actives ABANS del primer deploy
